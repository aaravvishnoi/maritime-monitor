# ── AIS Data Providers ─────────────────────────────────────────────────────
# All three can run simultaneously. Each one adds more coverage.

# Provider 1: AISStream.io — real-time WebSocket, coastal coverage (~50km shore)
# Free key at https://aisstream.io
VITE_AISSTREAM_API_KEY=your_key_here

# Provider 2: AISHub — 1,200+ community stations globally, free
# Register at https://www.aishub.net → you get a username
VITE_AISHUB_USERNAME=your_username

# Provider 3: DataDocked — SATELLITE AIS, 800,000+ vessels, global ocean coverage
# Free trial (no credit card) at https://datadocked.com
VITE_DATADOCKED_API_KEY=your_key_here
